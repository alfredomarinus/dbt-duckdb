# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_WITH_FERNET_KEY
AIRFLOW__CORE__INTERNAL_API_SECRET_KEY=CHANGE_ME_WITH_INTERNAL_API_SECRET_KEY
AIRFLOW__API__SECRET_KEY=CHANGE_ME_WITH_API_SECRET_KEY
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:CHANGE_ME_WITH_REDIS_PASSWORD@redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow

# Timezone
TZ=Asia/Kuala_Lumpur

# PostgreSQL Configuration
POSTGRES_USER=airflow
POSTGRES_PASSWORD=CHANGE_ME_WITH_POSTGRES_PASSWORD
POSTGRES_DB=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_WITH_REDIS_PASSWORD

# MinIO Configuration (S3-compatible storage)
MINIO_ROOT_USER=CHANGE_ME_WITH_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_WITH_MINIO_PASSWORD
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_WITH_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_WITH_MINIO_SECRET_KEY
MINIO_BUCKET=iceberg

# DuckDB Configuration
DUCKDB_CATALOG_PATH=/opt/airflow/duckdb
DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4

# Optional: Airflow Additional Requirements
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-docker apache-airflow-providers-amazon apache-airflow-providers-http
